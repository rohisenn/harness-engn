HARNESS_PROVIDER=gemini

GOOGLE_API_KEY=your-google-api-key
HARNESS_GEMINI_MODEL=gemini-3.5-flash

GROK_API_KEY=your-grok-api-key
HARNESS_GROK_MODEL=llama-3.3-70b-versatile

HARNESS_MAX_TOKENS=4096

# Context compression: compress history when estimated tokens exceed this threshold
# HARNESS_CONTEXT_WINDOW=6000
# Number of most-recent messages to keep verbatim after compression
# HARNESS_COMPRESS_TAIL=10
